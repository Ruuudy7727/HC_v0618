# Gemini chat (answer generation)
MIDEA_API_KEY=
GEMINI_AIMP_BIZ_ID=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
MIDEA_AIGC_USER=

# Embedding backend: online（生产推荐）| ollama（本地开发）
EMBED_BACKEND=online
EMBED_BASE_URL=https://aimpapi.midea.com/t-aigc/aimp-text-embedding/v1
EMBED_API_KEY=
EMBED_MODEL=Qwen3-Embedding-4B
EMBED_TIMEOUT=120
EMBED_BATCH_SIZE=16
EMBED_BATCH_INTERVAL=1.0
EMBED_MAX_RETRIES=8
EMBED_RETRY_BASE_DELAY=2.0
# 查询时子 embedding 调用间隔（秒），减轻 429 限流
EMBED_QUERY_INTERVAL=0.35
# 相同 query 的 embedding 内存缓存条数，0 表示关闭
EMBED_QUERY_CACHE_SIZE=256

# 本地开发用 Ollama embedding 时取消注释：
# EMBED_BACKEND=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# EMBED_MODEL=qwen3-embedding:4b

# Chroma vector store
CHROMA_PERSIST_DIR=./rag_data/all
CHROMA_COLLECTION_NAME=gsc_manual_kb

# API auth
PUBLIC_API_TOKEN=changeme

# Retrieval tuning
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_TOP_K=4
# 话题扩展子查询上限（每条用户问题可能触发多次 embedding）
RETRIEVAL_TOPIC_EXTRA_MAX=3
RETRIEVAL_FETCH_K=20
RETRIEVAL_SCORE_GAP=0.25
RETRIEVAL_MIN_KEEP=2

# Cross-Encoder rerank (BGE)
RERANK_ENABLED=true
# HuggingFace 模型 id（首次自动下载）或本机目录绝对路径
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_CANDIDATE_K=15
RERANK_SNIPPET_CHARS=512
RERANK_USE_FP16=true
