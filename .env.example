# Gemini chat (answer generation)
MIDEA_API_KEY=
GEMINI_AIMP_BIZ_ID=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# 流式接口 URL（默认由 sync v1 推导为 stream v2）
# GEMINI_URL_STREAM=https://aimpapi.midea.com/t-aigc/mip-chat-app/gemini/official/standard/stream/v2/chat/completions
MIDEA_AIGC_USER=

# Embedding backend: online（生产推荐）| ollama（本地开发）
EMBED_BACKEND=online
EMBED_BASE_URL=https://aimpapi.midea.com/t-aigc/aimp-text-embedding/v1
EMBED_API_KEY=
EMBED_MODEL=Qwen3-Embedding-4B
EMBED_TIMEOUT=120
EMBED_BATCH_SIZE=16
EMBED_BATCH_INTERVAL=1.0
EMBED_MAX_RETRIES=8
EMBED_RETRY_BASE_DELAY=2.0
EMBED_QUERY_INTERVAL=0.35
EMBED_QUERY_CACHE_SIZE=256

# 本地开发用 Ollama embedding 时取消注释：
# EMBED_BACKEND=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# EMBED_MODEL=qwen3-embedding:4b

# Chroma vector store
CHROMA_PERSIST_DIR=./rag_data/all
CHROMA_COLLECTION_NAME=hc_residential_platform_kb

# API auth
PUBLIC_API_TOKEN=changeme
# API 对外地址（前端拼接图片 URL 用；设置后 answer 内图片自动转为完整 HTTPS 地址）
API_PUBLIC_URL=https://aiops.szclou.com:50200

# Retrieval tuning
RETRIEVAL_MIN_SCORE=0.15
RETRIEVAL_TOP_K=4
RETRIEVAL_TOPIC_EXTRA_MAX=3
RETRIEVAL_FETCH_K=20
RETRIEVAL_SCORE_GAP=0.25
RETRIEVAL_MIN_KEEP=2

# Cross-Encoder rerank（关闭则无需安装 FlagEmbedding / torch）
RERANK_ENABLED=false

GEMINI_VISION_ENABLED=true
GEMINI_MAX_IMAGES=5
GRADIO_PORT=7860
# Gradio UI 配图公网地址（Chatbot 内需用完整 URL 才能显示图片）
GRADIO_PUBLIC_URL=https://aiops.szclou.com:50201
